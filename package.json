{
  "name": "te-op1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wrangler pages dev --proxy 5173 --port 8788\"",
    "build": "vite build",
    "typecheck": "tsc -b",
    "preview": "vite preview",
    "db:migrate:local": "wrangler d1 migrations apply te-op1-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply te-op1-db --remote",
    "seed:local": "node scripts/seed.mjs --local",
    "seed:remote": "node scripts/seed.mjs --remote",
    "deploy": "vite build && wrangler pages deploy ./dist"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240000.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.6.0",
    "vite": "^6.0.0",
    "wrangler": "^4.0.0"
  }
}
